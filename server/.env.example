# Server config
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=replace-this-with-your-mongodb-uri

# JWT - generate with: openssl rand -base64 48 (must be 32+ chars)
JWT_SECRET=replace-this-with-a-long-random-secret-32-chars-min
JWT_EXPIRES_IN=7d

# Client URL (used for CORS and invite links)
CLIENT_URL=http://localhost:5173

# Cloudinary - get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=replace-this-with-your-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-this-with-your-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-this-with-your-cloudinary-api-secret

# SMTP - Mailtrap for dev, Resend/Postmark/SendGrid for prod
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=replace-this-with-your-smtp-user
EMAIL_PASS=replace-this-with-your-smtp-password
EMAIL_FROM="SaaS Dashboard <replace-this-with-sender@example.test>"

# Logging
LOG_LEVEL=debug

# Docs visibility (true exposes /api/docs in production - keep false unless intentional)
EXPOSE_DOCS_IN_PROD=false

# Super admin seed (used only by `npm run seed:admin`, then rotate)
SUPER_ADMIN_EMAIL=replace-this-with-super-admin@example.test
SUPER_ADMIN_PASSWORD=replace-this-with-strong-password-then-rotate
